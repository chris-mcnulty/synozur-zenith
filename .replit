modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm run db:push -- --force && npm run build"]
publicDir = "dist/public"
run = ["node", "./dist/index.cjs"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-notifications"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-notifications-e2e"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "test-notifications"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "tsx --test server/routes/__tests__/notifications.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-notifications-e2e"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx playwright test e2e/notifications.spec.ts"

[agent]
stack = "MOCKUP_JS"
mockupState = "FULLSTACK"
integrations = ["github:1.0.0", "sendgrid:1.0.0", "javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.shared]
